# YouTube Data API v3 key (Google Cloud Console)
YOUTUBE_API_KEY=xxxx

# YouTube channel IDs to monitor — comma-separated, each starts with UC...
# Example: UCxxxxxxxxxxxxxxxxxxxxxx,UCyyyyyyyyyyyyyyyyyyyyyy
YOUTUBE_CHANNEL_IDS=UCxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Sender Gmail account (use an App Password, not your real password)
GMAIL_ADDRESS=sender@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Recipient(s) — comma-separated, can be one or many gmail addresses
# Example: me@gmail.com,friend@gmail.com
EMAIL_TO=recipient@gmail.com

# How many hours back to look for new videos (default 24)
LOOKBACK_HOURS=24

# Persona that steers the summary's tone and "why it matters" framing.
# Change this to make the digest read as if it were written FOR you.
# Examples:
#   "a software engineer evaluating new tools and frameworks for their team"
#   "a product manager hunting for user-research signals and growth patterns"
#   "a founder scanning for fundraising, GTM, and competitive moves"
# In GitHub Actions this is set via repo Variables (Settings > Secrets and variables > Actions > Variables tab).
VIEWER_PROFILE=an aspiring innovation/transformation director who scans these to brief leadership and spot strategic signals worth acting on
